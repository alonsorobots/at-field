{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AT-Field",
  "version": "0.3.0",
  "identifier": "dev.atfield.tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AT-Field",
        "width": 1160,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8765 ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Hardware watchdog UI for AI workloads on Windows",
    "longDescription": "AT-Field is an always-on hardware watchdog for AI workloads on Windows. This tray app gives you a live dashboard over the watchdog service: signal sparklines, rule verdicts, recent events, and a one-click pause toggle.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dist/atfield/atf.exe": "atfield/atf.exe",
      "../../dist/atfield/atfield-service.exe": "atfield/atfield-service.exe",
      "../../dist/atfield/_internal": "atfield/_internal",
      "../../dist/atfield/_internal/scripts": "atfield/scripts",
      "../../dist/atfield/LibreHardwareMonitor.exe": "atfield/LibreHardwareMonitor.exe",
      "../../dist/atfield/LibreHardwareMonitor.exe.config": "atfield/LibreHardwareMonitor.exe.config",
      "../../dist/atfield/LibreHardwareMonitor.config": "atfield/LibreHardwareMonitor.config",
      "../../dist/atfield/LibreHardwareMonitorLib.dll": "atfield/LibreHardwareMonitorLib.dll",
      "../../dist/atfield/LibreHardwareMonitorLib.xml": "atfield/LibreHardwareMonitorLib.xml",
      "../../dist/atfield/Aga.Controls.dll": "atfield/Aga.Controls.dll",
      "../../dist/atfield/HidSharp.dll": "atfield/HidSharp.dll",
      "../../dist/atfield/Microsoft.Win32.TaskScheduler.dll": "atfield/Microsoft.Win32.TaskScheduler.dll",
      "../../dist/atfield/Newtonsoft.Json.dll": "atfield/Newtonsoft.Json.dll",
      "../../dist/atfield/OxyPlot.dll": "atfield/OxyPlot.dll",
      "../../dist/atfield/OxyPlot.WindowsForms.dll": "atfield/OxyPlot.WindowsForms.dll",
      "../../dist/atfield/System.CodeDom.dll": "atfield/System.CodeDom.dll"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
