{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AT-Field",
  "version": "0.4.4",
  "identifier": "dev.atfield.tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AT-Field",
        "width": 1160,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8765 ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Hardware watchdog for heavy GPU/CPU workloads on Windows",
    "longDescription": "AT-Field is an always-on hardware watchdog for GPU rigs on Windows. It kills runaway workloads -- AI training, renders, simulations -- before thermal or memory runaway crashes or damages your machine. This tray app is a live dashboard over the watchdog service: signal sparklines, rule verdicts, recent events, and a one-click pause toggle.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dist/atfield/atf.exe": "atfield/atf.exe",
      "../../dist/atfield/atfield-service.exe": "atfield/atfield-service.exe",
      "../../dist/atfield/atfield-sensors.exe": "atfield/atfield-sensors.exe",
      "../../dist/atfield/_internal": "atfield/_internal",
      "../../dist/atfield/LibreHardwareMonitor.exe": "atfield/LibreHardwareMonitor.exe",
      "../../dist/atfield/LibreHardwareMonitor.exe.config": "atfield/LibreHardwareMonitor.exe.config",
      "../../dist/atfield/LibreHardwareMonitorLib.dll": "atfield/LibreHardwareMonitorLib.dll",
      "../../dist/atfield/Aga.Controls.dll": "atfield/Aga.Controls.dll",
      "../../dist/atfield/BlackSharp.Core.dll": "atfield/BlackSharp.Core.dll",
      "../../dist/atfield/DiskInfoToolkit.dll": "atfield/DiskInfoToolkit.dll",
      "../../dist/atfield/HidSharp.dll": "atfield/HidSharp.dll",
      "../../dist/atfield/Microsoft.Bcl.AsyncInterfaces.dll": "atfield/Microsoft.Bcl.AsyncInterfaces.dll",
      "../../dist/atfield/Microsoft.Bcl.HashCode.dll": "atfield/Microsoft.Bcl.HashCode.dll",
      "../../dist/atfield/Microsoft.Win32.TaskScheduler.dll": "atfield/Microsoft.Win32.TaskScheduler.dll",
      "../../dist/atfield/OxyPlot.dll": "atfield/OxyPlot.dll",
      "../../dist/atfield/OxyPlot.WindowsForms.dll": "atfield/OxyPlot.WindowsForms.dll",
      "../../dist/atfield/RAMSPDToolkit-NDD.dll": "atfield/RAMSPDToolkit-NDD.dll",
      "../../dist/atfield/System.Buffers.dll": "atfield/System.Buffers.dll",
      "../../dist/atfield/System.CodeDom.dll": "atfield/System.CodeDom.dll",
      "../../dist/atfield/System.Collections.Immutable.dll": "atfield/System.Collections.Immutable.dll",
      "../../dist/atfield/System.Formats.Nrbf.dll": "atfield/System.Formats.Nrbf.dll",
      "../../dist/atfield/System.IO.Pipelines.dll": "atfield/System.IO.Pipelines.dll",
      "../../dist/atfield/System.Memory.dll": "atfield/System.Memory.dll",
      "../../dist/atfield/System.Numerics.Vectors.dll": "atfield/System.Numerics.Vectors.dll",
      "../../dist/atfield/System.Reflection.Metadata.dll": "atfield/System.Reflection.Metadata.dll",
      "../../dist/atfield/System.Resources.Extensions.dll": "atfield/System.Resources.Extensions.dll",
      "../../dist/atfield/System.Runtime.CompilerServices.Unsafe.dll": "atfield/System.Runtime.CompilerServices.Unsafe.dll",
      "../../dist/atfield/System.Security.AccessControl.dll": "atfield/System.Security.AccessControl.dll",
      "../../dist/atfield/System.Security.Principal.Windows.dll": "atfield/System.Security.Principal.Windows.dll",
      "../../dist/atfield/System.Text.Encodings.Web.dll": "atfield/System.Text.Encodings.Web.dll",
      "../../dist/atfield/System.Text.Json.dll": "atfield/System.Text.Json.dll",
      "../../dist/atfield/System.Threading.AccessControl.dll": "atfield/System.Threading.AccessControl.dll",
      "../../dist/atfield/System.Threading.Tasks.Extensions.dll": "atfield/System.Threading.Tasks.Extensions.dll"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  }
}
