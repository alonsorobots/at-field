<?xml version="1.0" encoding="utf-8"?>
<!--
  AT-Field's pre-baked LHM settings. Dropped next to LibreHardwareMonitor.exe
  by scripts/fetch_lhm.ps1 so the bundled LHM starts up with the web server
  enabled on the port the AT-Field collector reads (127.0.0.1:8085) without
  the user having to click through LHM's GUI.

  LHM persists user preferences here on every change; if a user later opens
  the LHM window and tweaks something, this file gets overwritten. That's
  fine -- the only settings AT-Field actually depends on are the web server
  ones, and LHM preserves any unrelated keys.

  Keys mirror what LHM writes when you check "Run web server" + set the
  port in Options. We only set the keys we care about; LHM falls back to
  defaults for anything we omit.
-->
<configuration>
  <appSettings>
    <!-- Enable the HTTP sensor server. Without this, LHM still collects
         sensors but doesn't expose data.json. -->
    <add key="runWebServerMenuItem" value="True" />

    <!-- Port the AT-Field LHM collector reads. Must match the port in
         src/atfield/collectors/lhm.py (default 8085). -->
    <add key="webServerPortNumeric.Value" value="8085" />

    <!-- Start minimized to the LHM tray icon so we don't pop a window
         on every service boot. The user can still right-click the LHM
         tray icon if they want the full sensor tree UI. -->
    <add key="minimizeToTrayMenuItem" value="True" />
    <add key="startMinMenuItem" value="True" />

    <!-- Don't auto-update LHM; AT-Field manages the bundled version
         and an update from inside LHM would point to a different binary
         than the supervisor knows about. -->
    <add key="checkUpdatesAtStartMenuItem" value="False" />
  </appSettings>
</configuration>
